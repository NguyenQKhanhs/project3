@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}
@model List<Project3.Models.Class>
<br />
<br />
<br />
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold mb-4">Class Management</h5>
            <div class="card">
                <div class="card-body p-4">
                    <div class="container mt-1 px-2">

                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <div class="d-flex">
                                <input type="text" class="form-control" placeholder="Search">
                                <button type="button" class="btn btn-primary btn-search ms-2">Search</button>
                            </div>
                            <div>
                                <a asp-controller="Admin" asp-action="admin_class_add" class="btn btn-outline-secondary btn-add m-1">Add Class</a>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-responsive table-borderless">
                                <thead>
                                    <tr class="bg-light">
                                        <th scope="col" width="30%">Course</th>
                                        <th>Instructor</th>
                                        <th>Description</th>
                                        <th scope="col" width="10%">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var classItem in Model)
                                        {
                                            <tr>
                                                <td style="border: 1px solid black;">@classItem.Course?.Name</td>
                                                <td>@classItem.Instructor?.Name</td>
                                                <td>@classItem.Description</td>
                                                <td class="d-flex align-items-center justify-content-between td-action">
                                                    <form method="post" asp-action="admin_class_delete" asp-route-id="@classItem.ClassesId" onsubmit="return confirm('Are you sure you want to delete this class?');">
                                                        <button type="submit" class="btn btn-outline-danger m-1">Delete</button>
                                                    </form>
                                                    <a asp-controller="Admin" asp-action="admin_class_edit" asp-route-id="@classItem.ClassesId" class="btn btn-outline-success m-1">Edit</a>
                                                    <a asp-controller="Admin" asp-action="admin_class_student" asp-route-id="@classItem.ClassesId" class="btn btn-outline-primary m-1">View</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center">No classes found.</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
