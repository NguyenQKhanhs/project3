@model Project3.Models.Course
@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold mb-4"></h5>
            <div class="card">
                <div class="card-body m-2 custom-bg">
                    <h1 class="text-center">Edit Course</h1>
                    <div class="container mt-1 px-2">
                        <form asp-action="admin_course_edit" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="CourseId" value="@Model.CourseId" />

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Name</label>
                                <input asp-for="Name" class="form-control w-100" style="height:50px" placeholder="Enter Course Name" required>
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Description</label>
                                <textarea asp-for="Description" class="form-control w-100" placeholder="Enter Course Description" rows="8" required></textarea>
                                <span asp-validation-for="Description" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Course Content</label>
                                <textarea asp-for="Content" class="form-control w-100" placeholder="Enter Course Content (one topic per line)" rows="8" required></textarea>
                                <span asp-validation-for="Content" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Price</label>
                                <input asp-for="Price" class="form-control w-100" style="height:50px" step="0.01" placeholder="Enter Course Price" required>
                                <span asp-validation-for="Price" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Start Date</label>
                                <input asp-for="StartDate" type="date" class="form-control w-100" style="height:50px" required>
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Exam Date</label>
                                <input asp-for="ExamDate" type="date" class="form-control w-100" style="height:50px" required>
                                <span asp-validation-for="ExamDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Study Level</label>
                                <select asp-for="StudyLevel" class="form-control w-100" style="height:50px" required>
                                    <option value="">Select Level</option>
                                    <option value="Beginner">Beginner</option>
                                    <option value="Intermediate">Intermediate</option>
                                    <option value="Advanced">Advanced</option>
                                </select>
                                <span asp-validation-for="StudyLevel" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Duration (in weeks)</label>
                                <input asp-for="Duration" type="number" class="form-control w-100" style="height:50px" placeholder="Enter Duration in Weeks" min="1" required>
                                <span asp-validation-for="Duration" class="text-danger"></span>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Course Image</label>
                                <input type="file" name="image" class="form-control w-100" style="height:50px">
                                <p class="mt-2">Current Image: <img src="ImageUrl" alt="Current Image" style="height: 100px;"></p>
                            </div>

                            <div class="col-md-8 mx-auto">
                                <label class="labels">Category</label>
                                <select asp-for="CategoryId" class="form-control w-100" style="height:50px" required>
                                    <option value="">Select Category</option>
                                    <option value="1">Frontend</option>
                                    <option value="2">Backend</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger"></span>
                            </div>

                            <div class="text-end col-md-8 mx-auto">
                                <button type="submit" class="btn btn-outline-success m-1">Update Course</button>
                                <a asp-area="" asp-controller="Admin" asp-action="admin_course" class="btn btn-outline-secondary m-1">Back</a>
                            </div>

                            @if (ViewBag.Message != null)
                            {
                                <p class="text-danger">@ViewBag.Message</p>
                            }
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
