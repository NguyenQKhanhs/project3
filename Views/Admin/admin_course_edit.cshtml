@model Project3.Models.Course
@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}
<br />
<br />
<br />
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold mb-4"></h5>
            <div class="card">
                <div class="card-body p-4">
                    <h1 class="text-center text-light">Edit Course</h1>
                    <div class="container mt-5 px-2 d-flex justify-content-center">
                        <div class="table-responsive col-md-8">
                            <table class="table table-borderless">
                                <tbody>
                                    <tr>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Name</label>
                                            <input asp-for="Name" class="form-control" style="height: 50px; font-size: 1.2rem;" placeholder="Enter Course Name" required>
                                            <span asp-validation-for="Name" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Price</label>
                                            <input asp-for="Price" class="form-control" style="height: 50px; font-size: 1.2rem;" step="0.01" placeholder="Enter Course Price" required>
                                            <span asp-validation-for="Price" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Start Date</label>
                                            <input asp-for="StartDate" type="date" class="form-control" style="height: 50px; font-size: 1.2rem;" required>
                                            <span asp-validation-for="StartDate" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Exam Date</label>
                                            <input asp-for="ExamDate" type="date" class="form-control" style="height: 50px; font-size: 1.2rem;" required>
                                            <span asp-validation-for="ExamDate" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Study Level</label>
                                            <select asp-for="StudyLevel" class="form-control" style="height: 50px; font-size: 1.2rem;" required>
                                                <option value="">Select Level</option>
                                                <option value="Beginner">Beginner</option>
                                                <option value="Intermediate">Intermediate</option>
                                                <option value="Advanced">Advanced</option>
                                            </select>
                                            <span asp-validation-for="StudyLevel" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Duration (in weeks)</label>
                                            <input asp-for="Duration" type="number" class="form-control" style="height: 50px; font-size: 1.2rem;" placeholder="Enter Duration in Weeks" min="1" required>
                                            <span asp-validation-for="Duration" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Description</label>
                                            <textarea asp-for="Description" class="form-control" style="font-size: 1.2rem;" placeholder="Enter Course Description" rows="8" required></textarea>
                                            <span asp-validation-for="Description" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Course Content</label>
                                            <textarea asp-for="Content" class="form-control" style="font-size: 1.2rem;" placeholder="Enter Course Content (one topic per line)" rows="9" required></textarea>
                                            <span asp-validation-for="Content" class="text-danger"></span>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Course Image</label>
                                            <input type="file" name="image" class="form-control" style="height: 50px; font-size: 1.2rem;" />
                                            <p class="mt-2">Current Image: <img src="@Model.ImageUrl" alt="Current Image" style="height: 100px;"></p>
                                        </div>
                                        <div class="col-md-12 mb-3">
                                            <label class="labels">Category</label>
                                            <select asp-for="CategoryId" class="form-control" style="height: 50px; font-size: 1.2rem;" required>
                                                <option value="">Select Category</option>
                                                <option value="1">Frontend</option>
                                                <option value="2">Backend</option>
                                            </select>
                                            <span asp-validation-for="CategoryId" class="text-danger"></span>
                                        </div>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="text-end">
                                <button type="submit" class="btn btn-outline-success m-1">Save</button>
                                <a asp-area="" asp-controller="Admin" asp-action="admin_course" class="btn btn-outline-secondary m-1">Back</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
