@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}
@model List<Project3.Models.Instructor>
<br>
<br>
<br>

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold "></h5>
            <div class="card">
                <div class="card-body p-4">
                    <div class="container mt-1 px-2">
                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <div class="d-flex">
                                <input type="text" class="form-control" placeholder="Search">
                                <button type="button" class="btn btn-primary btn-search ms-2">Search</button>
                            </div>
                            <div><a asp-area="" asp-controller="Admin" asp-action="admin_instructor_add" class="btn btn-outline-secondary btn-add m-1">Add</a></div>

                        </div>
                        <div class="table-responsive">
                            <table class="table table-responsive table-borderless">

                                <thead>
                                    <tr class="">

                                        <th>Name</th>
                                        <th>Gender</th>
                                        <th>Bio</th>
                                        <th>Phone Number</th>
                                        <th>Email</th>
                                        <th>Image</th>
                                        
                                        <th scope="col" width="10%">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var instructors in Model)
                                    {
                                        <tr>
                                            <td>@instructors.Name</td>
                                            <td>@instructors.Gender</td>
                                            <td><i class="fa fa-check-circle-o green"></i><span class="ms-1">@instructors.Bio</span></td>
                                            <td>@instructors.PhoneNumber</td>
                                            <td>@instructors.Email</td>
                                            <td><img src="@instructors.ImageLink" alt="" style="height: 50px;"></td>
                                            <td class="d-flex align-items-center justify-content-between td-action">
                                                <form method="post" asp-action="admin_instructor_delete" asp-route-id="@instructors.InstructorId" onsubmit="return confirm('Are you sure you want to delete this intructor?');">
                                                    <button type="submit" class="btn btn-outline-danger m-1">Delete</button>
                                                </form>
                                                <a asp-area="" asp-controller="Admin" asp-action="admin_instructor_edit" asp-route-id="@instructors.InstructorId" class="btn btn-outline-success m-1">Edit</a>
                                                
                                            </td>
                                        </tr>




                                    }
                                </tbody>
                            </table>

                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>

</div>