@model Project3.Models.Instructor

@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}

<br />
<br />
<br />

<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold mb-4"></h5>
            <div class="card">
                <div class="card-body p-4">
                    <h1>Add Instructor</h1>
                    <div class="container mt-5 px-2">
                        <div class="table-responsive">
                            <form asp-action="admin_instructor_add" method="post" enctype="multipart/form-data">
                                <!-- Tên -->
                                <div class="col-md-12">
                                    <label asp-for="Name" class="form-label">Name</label>
                                    <input asp-for="Name" class="form-control" placeholder="Enter Instructor Name" required />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                <!-- Giới tính -->
                                <div class="col-md-12 mt-3">
                                    <label class="form-label">Gender</label>
                                    <div>
                                        <input type="radio" asp-for="Gender" value="Male" id="genderMale" />
                                        <label for="genderMale">Male</label>
                                    </div>
                                    <div>
                                        <input type="radio" asp-for="Gender" value="Female" id="genderFemale" />
                                        <label for="genderFemale">Female</label>
                                    </div>
                                    <div>
                                        <input type="radio" asp-for="Gender" value="Other" id="genderOther" />
                                        <label for="genderOther">Other</label>
                                    </div>
                                    <span asp-validation-for="Gender" class="text-danger"></span>
                                </div>

                                <!-- Tiểu sử -->
                                <div class="col-md-12 mt-3">
                                    <label asp-for="Bio" class="form-label">Bio</label>
                                    <textarea asp-for="Bio" class="form-control" placeholder="Enter Instructor Bio" required></textarea>
                                    <span asp-validation-for="Bio" class="text-danger"></span>
                                </div>

                                <!-- Số điện thoại -->
                                <div class="col-md-12 mt-3">
                                    <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                                    <input asp-for="PhoneNumber" type="text" class="form-control" placeholder="Enter Phone Number" required />
                                    <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                                </div>

                                <!-- Email -->
                                <div class="col-md-12 mt-3">
                                    <label asp-for="Email" class="form-label">Email</label>
                                    <input asp-for="Email" type="email" class="form-control" placeholder="Enter Email Address" required />
                                    <span asp-validation-for="Email" class="text-danger"></span>
                                </div>

                                <!-- Ảnh -->
                                <div class="col-md-12 mt-3">
                                    <label class="form-label">Upload Image</label>
                                    <input type="file" name="Image" class="form-control" required />
                                </div>

                                <!-- Nút thêm -->
                                <div class="mt-4">
                                    <button type="submit" class="btn btn-primary">Add Instructor</button>
                                    <a asp-action="admin_instructor" class="btn btn-secondary">Cancel</a>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
