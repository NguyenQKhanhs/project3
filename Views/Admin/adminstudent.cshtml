@model IEnumerable<Project3.Models.CustomerInformation>

@{
    Layout = "~/Views/Shared/_layoutadmin.cshtml";
}
<br /><br /><br />
<div class="container-fluid">
    <div class="card">
        <div class="card-body">
            <h5 class="card-title fw-semibold mb-4"></h5>
            <div class="card">
                <div class="card-body p-4">
                    <div class="container mt-5 px-2">

                        <div class="mb-3 d-flex justify-content-between align-items-center">
                            <div class="d-flex">
                                <input type="text" class="form-control" placeholder="Search">
                                <button type="button" class="btn btn-primary btn-search ms-2">Search</button>
                            </div>
                            <div>
                                <a asp-controller="Admin" asp-action="admin_student_add" class="btn btn-outline-secondary btn-add m-1">Add</a>
                            </div>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-responsive table-borderless">

                                <thead>
                                    <tr class="bg-light">


                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Phone Number</th>
                                        <th>Mark</th>
                                        <th>Image</th>
                                        <th>Status</th>
                                        <th scope="col" width="10%">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (Model != null && Model.Any())
                                    {
                                        foreach (var item in Model)
                                        {
                                            <tr>
                                                <td>@item.CustomerInformationId</td>
                                                <td>@item.FullName</td>
                                                <td>@item.Email</td>
                                                <td>@item.PhoneNumber</td>
                                                <td>@item.Mark?.ToString("F2")</td>
                                                <td>@item.ImageLink</td>
                                                <td>@item.Status</td>
                                                
                                                <td class="d-flex align-items-center justify-content-between td-action">
                                                    <form method="post" asp-action="admin_course_delete" asp-route-id="@item.CustomerInformationId" onsubmit="return confirm('Are you sure you want to delete this course?');">
                                                        <button type="submit" class="btn btn-outline-danger m-1">Delete</button>
                                                    </form>
                                                    <a asp-area="" asp-controller="Admin" asp-action="admin_course_edit" asp-route-id="@item.CustomerInformationId" class="btn btn-outline-success m-1">Edit</a>
                                                    <a asp-area="" asp-controller="Admin" asp-action="admin_course_view" asp-route-id="@item.CustomerInformationId" class="btn btn-outline-primary m-1">View</a>
                                                </td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr>
                                            <td colspan="8" class="text-center">No customer information available.</td>
                                        </tr>
                                    }


                                



                                </tbody>
                            </table>
                            
                        </div>

                    </div>
                </div>
            </div>

        </div>
    </div>

</div>


